{
  "manifest_version": 3,
  "name": "Meet Recorder",
  "description": "Record Google Meet sessions with tab audio + microphone. Save locally or to the cloud.",
  "version": "1.0.0",

  "permissions": [
    "tabCapture",
    "offscreen",
    "downloads",
    "activeTab",
    "storage",
    "cookies"
  ],

  "host_permissions": [
    "https://meet.google.com/*",
    "http://localhost:3000/*",
    "https://*.vercel.app/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    },
    {
      "matches": ["http://localhost:3000/*", "https://*.vercel.app/*"],
      "js": ["dashboard-bridge.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dashboard-page-session.js"],
      "matches": ["http://localhost:3000/*", "https://*.vercel.app/*"]
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
